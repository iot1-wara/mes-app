# ============================================
# MES Production Control System - Environment
# ============================================

# --- Database (PostgreSQL/TimescaleDB) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mes_admin
DB_PASSWORD=your_secure_password_here
DB_DATABASE=mes_production

# --- JWT Authentication ---
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# --- OPC UA Configuration ---
OPCUA_ENDPOINT_URL=opc.tcp://localhost:4840
OPCUA_SECURITY_MODE=none
OPCUA_POLL_INTERVAL_MS=5000

# --- MQTT Configuration ---
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=mes-edge-gateway
MQTT_QOS=1

# --- Application ---
PORT=3000
NODE_ENV=development
